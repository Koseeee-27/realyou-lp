import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import WhatWeMeasure from '../components/WhatWeMeasure.astro';
import Results from '../components/Results.astro';
import Craft from '../components/Craft.astro';
import Footer from '../components/Footer.astro';

const title = 'Real You 〜本当の私じゃだめですか？〜';
const description =
  'その診断、“理想の自分”で答えてない？ ゲーム中の無意識の行動から、本当の性格を5つの軸で診断する性格診断アプリ。';
---

<Base title={title} description={description}>
  <Header current="home" />
  <Hero />
  <Problem />
  <WhatWeMeasure />
  <Results />
  <Craft />
  <Footer />
</Base>
