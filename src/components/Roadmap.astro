---
// 今後の展望 — ポップさを抑え、シンプルな箇条リストでまとめる。
const ITEMS = [
  { title: 'ゲームの追加', body: '様々なシチュエーションのゲームを増やし、多角的に診断する。' },
  { title: '診断ロジックの精度向上', body: '行動データからより正確に性格を導けるよう改善する。' },
  { title: 'データ蓄積による比較の充実', body: 'ユーザーが増えるほど「みんなとの違い」を見せられるようにする。' },
] as const;
---

<section class="section">
  <div class="section__inner">
    <h2 class="section-title"><span class="marker">今後の展望</span></h2>

    <ul class="list">
      {
        ITEMS.map((item) => (
          <li class="item">
            <span class="item-title">{item.title}</span>
            <span class="item-body">{item.body}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 2px solid var(--ink);
  }

  .item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 0;
    border-bottom: 2px solid var(--ink);
  }

  .item-title {
    font-weight: 900;
    font-size: 1.1rem;
  }

  .item-body {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.92rem;
  }

  @media (min-width: 720px) {
    .item {
      flex-direction: row;
      align-items: baseline;
      gap: 1.5rem;
    }

    .item-title {
      flex: 0 0 14rem;
    }
  }
</style>
