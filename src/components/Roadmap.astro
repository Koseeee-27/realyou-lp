---
// 4-6. 今後の展望 — 軽いトーンで 3 つ
const ITEMS = [
  {
    emoji: '🎮',
    title: 'ゲームの追加',
    body: '色々なシチュエーションのゲームを増やして、多角的に診断。',
  },
  {
    emoji: '🎯',
    title: '診断ロジックの精度向上',
    body: '行動データからもっと正確に性格を導けるよう進化中。',
  },
  {
    emoji: '📈',
    title: 'データ蓄積でもっと面白く',
    body: 'ユーザーが増えるほど「みんなとの違い」の比較が充実。',
  },
] as const;
---

<section class="section">
  <h2 class="section-title"><span class="marker">今後の展望</span></h2>

  <ol class="roadmap">
    {
      ITEMS.map((item) => (
        <li class="item card">
          <span class="emoji">{item.emoji}</span>
          <div>
            <h3 class="item-title">{item.title}</h3>
            <p class="item-body">{item.body}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .roadmap {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .emoji {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .item-title {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .item-body {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
