---
// 4-3. 何を測っているか — 5 軸 + 3 ゲーム
// 生データの取得方法・スコアリングの数理は書かない(対外向けの粒度に留める)。
import { AXES, GAMES } from '../config';
---

<section class="section">
  <h2 class="section-title"><span class="marker">何を測っているか</span></h2>

  <div class="card intro">
    <p>
      Real You は、ゲーム中の<strong>“無意識の行動”</strong>を計測し、
      <strong>5 つの軸</strong>であなたの本当の性格を診断します。
    </p>
  </div>

  <!-- 5 つの診断軸 -->
  <h3 class="block-title">5 つの診断軸</h3>
  <ul class="axes">
    {
      AXES.map((axis) => (
        <li class="axis">
          <span class="axis-emoji">{axis.emoji}</span>
          <span class="axis-name">{axis.name}</span>
          <span class="axis-range">{axis.range}</span>
        </li>
      ))
    }
  </ul>

  <!-- 3 つのゲーム -->
  <h3 class="block-title">3 つのゲームで計測</h3>
  <div class="games">
    {
      GAMES.map((game) => (
        <article class="game" style={`--game-accent: ${game.accent}`}>
          <div class="game-no">GAME {game.no}</div>
          <h4 class="game-title">{game.title}</h4>
          <p class="game-summary">{game.summary}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .intro {
    font-size: clamp(1.05rem, 4.5vw, 1.25rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .intro strong {
    color: var(--accent-blue);
  }

  .block-title {
    font-size: 1.25rem;
    margin: 2rem 0 1rem;
  }

  /* 5 軸: 縦並びのタグ */
  .axes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .axis {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.6rem;
    background: var(--cream);
    border: var(--border);
    border-radius: 14px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 0.7rem 1rem;
  }

  .axis-emoji {
    font-size: 1.4rem;
  }

  .axis-name {
    font-weight: 900;
    font-size: 1.1rem;
  }

  .axis-range {
    text-align: right;
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* 3 ゲーム: カード */
  .games {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .game {
    background: var(--card);
    border: var(--border);
    border-left: 12px solid var(--game-accent);
    border-radius: 16px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 1.1rem 1.25rem;
  }

  .game-no {
    font-weight: 900;
    font-size: 0.85rem;
    color: var(--game-accent);
    letter-spacing: 0.08em;
  }

  .game-title {
    font-size: 1.3rem;
    margin: 0.2rem 0 0.4rem;
  }

  .game-summary {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.95rem;
  }

  /* PC では 5 軸を 2 段組みっぽく(横に余裕がある時) */
  @media (min-width: 600px) {
    .axis-range {
      font-size: 1rem;
    }
  }
</style>
