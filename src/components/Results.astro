---
// 結果の可視化 — スクショ2枚を2カラム + 注釈3カード(spec §4.1 ベース、余白を圧縮)。
// コア訴求: 自己申告 ▼ vs 行動から出た実測 ▼ を同じバーで並べてズレを見せる。
interface Shot {
  src: string;
  alt: string;
  caption: string;
}

const SHOTS: Shot[] = [
  {
    src: '/results/summary.png',
    alt: '結果サマリー画面。5 軸ごとに自己申告と行動から出た実測を対比バーで並べ、ズレを表示',
    caption: '結果サマリー（自己申告 ▼ vs 実測 ▼）',
  },
  {
    src: '/results/game-detail.png',
    alt: 'ゲーム別の詳細画面。各ゲームの行動データと、それが各軸スコアへどう寄与したかを表示',
    caption: 'ゲーム別の詳細（さらに深掘り）',
  },
];

const NOTES = [
  {
    n: '01',
    title: 'キャラ名で一目でわかる',
    body: '5 軸の結果を「無敵のポーカーフェイス」など覚えやすいキャラ名に。シェアしたくなる結果に。',
  },
  {
    n: '02',
    title: '自己認識のズレを数値化',
    body: '自己申告と、行動から出た実測の一致度を % で表示。ギャップが大きいほど発見がある。',
  },
  {
    n: '03',
    title: '盛れない行動エビデンス',
    body: '「機械が止まった 3 秒間、クリック 0 回（平均 3 回）」のように、無意識の行動データが結果の根拠。',
  },
] as const;
---

<section class="section section--cream" id="results">
  <div class="section__inner section__inner--wide">
    <h2 class="section-title"><span class="marker">結果の可視化</span></h2>

    <div class="card lead-card">
      <p>
        診断の結果は、<strong>「自分が思う自分」</strong>と<strong>「行動が示す自分」</strong>のギャップで見せます。
      </p>
    </div>

    <!-- スクショ2枚を2カラム。クリックで拡大表示 -->
    <ul class="shots">
      {
        SHOTS.map((shot) => (
          <li>
            <figure class="shot">
              <button
                type="button"
                class="shot-btn"
                data-zoom
                data-zoom-src={shot.src}
                data-zoom-caption={shot.caption}
                aria-label={`${shot.caption} を拡大表示`}
              >
                <img src={shot.src} alt={shot.alt} loading="lazy" />
                <span class="shot-zoom" aria-hidden="true">⤢ タップで拡大</span>
              </button>
              <figcaption class="shot-caption">{shot.caption}</figcaption>
            </figure>
          </li>
        ))
      }
    </ul>

    <!-- 拡大表示用ライトボックス(全スクショ共通で 1 つを使い回す) -->
    <dialog class="lightbox" id="result-lightbox" aria-label="結果画面の拡大表示">
      <button
        type="button"
        class="lightbox-close"
        data-zoom-close
        aria-label="閉じる"
      >
        ×
      </button>
      <figure class="lightbox-fig">
        <img class="lightbox-img" src="" alt="" />
        <figcaption class="lightbox-cap"></figcaption>
      </figure>
    </dialog>

    <!-- 注釈3カード -->
    <ul class="notes">
      {
        NOTES.map((note) => (
          <li class="note">
            <span class="note-no">{note.n}</span>
            <h3 class="note-title">{note.title}</h3>
            <p class="note-body">{note.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .lead-card {
    max-width: var(--max-content);
    font-size: clamp(1.1rem, 4.5vw, 1.4rem);
    font-weight: 700;
    margin-bottom: 1.75rem;
  }

  .lead-card strong {
    color: var(--accent-pink);
  }

  /* スクショ: モバイル1列 → PC 2カラム */
  .shots {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .shot {
    margin: 0;
  }

  /* 画像をボタン化して「クリックで拡大」できるようにする */
  .shot-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    position: relative;
    border-radius: var(--radius-lg);
  }

  .shot-btn img {
    width: 100%;
    height: auto;
    border: var(--border-thick);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    background: #fff;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .shot-btn:hover img {
    transform: translate(-2px, -2px);
    box-shadow: 13px 13px 0px var(--ink);
  }

  .shot-btn:active img {
    transform: translate(3px, 3px);
    box-shadow: 4px 4px 0 var(--ink);
  }

  /* 拡大できることを示すバッジ(右下) */
  .shot-zoom {
    position: absolute;
    right: 0.7rem;
    bottom: 0.7rem;
    font-weight: 900;
    font-size: 0.78rem;
    color: #fff;
    background: var(--ink);
    border: 2px solid #fff;
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    pointer-events: none;
  }

  .shot-caption {
    text-align: center;
    font-weight: 900;
    font-size: 0.9rem;
    color: var(--text-sub);
    margin-top: 0.7rem;
  }

  /* 注釈3カード */
  .notes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .note {
    background: var(--card);
    border: var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 1.2rem 1.3rem;
  }

  .note-no {
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1;
    color: var(--accent-pink);
    font-variant-numeric: tabular-nums;
  }

  .note-title {
    font-size: 1.1rem;
    margin: 0.35rem 0 0.35rem;
  }

  .note-body {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.88rem;
  }

  /* --- ライトボックス(拡大表示) --- */
  .lightbox {
    width: min(96vw, 1400px);
    max-width: none;
    max-height: 94vh;
    border: var(--border-thick);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    background: var(--cream);
    padding: 1rem;
    overflow: visible;
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .lightbox-fig {
    margin: 0;
  }

  .lightbox-img {
    width: 100%;
    max-height: 82vh;
    object-fit: contain;
    border: var(--border);
    border-radius: var(--radius);
    background: #fff;
  }

  .lightbox-cap {
    text-align: center;
    font-weight: 900;
    font-size: 0.95rem;
    margin-top: 0.75rem;
  }

  /* 閉じるボタン(右上に飛び出す) */
  .lightbox-close {
    position: absolute;
    top: -0.9rem;
    right: -0.9rem;
    width: 2.6rem;
    height: 2.6rem;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--ink);
    background: var(--accent-red);
    border: var(--border);
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--ink);
    cursor: pointer;
    transition: opacity 0.15s ease, transform 0.08s ease;
  }

  .lightbox-close:hover {
    opacity: 0.85;
  }

  .lightbox-close:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  @media (min-width: 720px) {
    .shots {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .notes {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }
</style>

<script>
  // 結果スクショのクリックで <dialog> を拡大表示する。
  // 1 つの dialog を全スクショで使い回し、押されたボタンの画像を差し込む。
  const dialog = document.getElementById('result-lightbox') as HTMLDialogElement | null;

  if (dialog) {
    const img = dialog.querySelector<HTMLImageElement>('.lightbox-img');
    const cap = dialog.querySelector<HTMLElement>('.lightbox-cap');

    document.querySelectorAll<HTMLButtonElement>('[data-zoom]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.dataset.zoomSrc ?? '';
        const caption = btn.dataset.zoomCaption ?? '';
        if (img) {
          img.src = src;
          img.alt = caption;
        }
        if (cap) cap.textContent = caption;
        dialog.showModal();
      });
    });

    // 閉じるボタン
    dialog
      .querySelector('[data-zoom-close]')
      ?.addEventListener('click', () => dialog.close());

    // 背景(dialog 自身)クリックで閉じる。中身クリックは閉じない
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
