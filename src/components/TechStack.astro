---
// 技術スタック ＆ システム構成(技術ページ) — spec §4.2。
//  PC: 2カラム（左=システム構成図 sticky / 右=技術スタックカード）
//  SP: 縦積み（上=技術スタック → 下=システム構成図）
//  カードは Frontend / Backend のみ。インフラ層は構成図下のリンク行に（config 単一ソースから派生）。
import { TECH_STACK, LINKS } from '../config';

const ARCH_IMAGE = '/architecture.svg';

// カード表示は Frontend / Backend のみ
const cardLayers = TECH_STACK.filter((l) => l.layer !== 'インフラ');
// インフラ層 → 構成図下のプラットフォームリンク行（+ GitHub）。名前で重複除去
const infra = TECH_STACK.find((l) => l.layer === 'インフラ');
const platformsRaw = [
  ...(infra?.items.map((i) => ({ name: i.name, href: i.href })) ?? []),
  { name: 'GitHub', href: LINKS.github },
];
const seen = new Set<string>();
const platforms = platformsRaw.filter((p) => (seen.has(p.name) ? false : seen.add(p.name)));
---

<section class="section section--white section--roomy" id="tech">
  <div class="section__inner section__inner--wide">
    <h2 class="section-title"><span class="marker">技術スタック</span></h2>

    <p class="note">
      技術を尖らせることより、<strong>プロダクトの本質</strong>を磨くことを優先。チームでアイデアを出し合いながら作りました。
    </p>

    <div class="grid">
      <!-- 技術スタックカード(SP:上 / PC:右) -->
      <div class="stack-col">
        <p class="hint">各技術をタップすると公式ドキュメントが開きます。</p>
        {
          cardLayers.map((group) => (
            <div class="layer">
              <h3 class="layer-name">{group.layer}</h3>
              <ul class="items">
                {group.items.map((item) => (
                  <li>
                    <a
                      class="tech"
                      href={item.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      style={`--tech-color: ${item.color}`}
                    >
                      {item.icon ? (
                        <span class="tech-logo" style={`--icon: url(/tech/${item.icon}.svg)`} />
                      ) : (
                        <span class="tech-logo is-text">{item.name.charAt(0)}</span>
                      )}
                      <span class="tech-name">{item.name}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- システム構成図(SP:下 / PC:左 sticky) -->
      <div class="arch-col">
        <h3 class="layer-name">システム構成</h3>
        <img
          class="arch-img"
          src={ARCH_IMAGE}
          alt="システム構成図（ユーザー → Vercel → Render → Supabase）"
          loading="lazy"
        />
        <div class="platforms">
          <span class="platforms-label">インフラ / プラットフォーム</span>
          <div class="platform-links">
            {
              platforms.map((p) => (
                <a href={p.href} target="_blank" rel="noopener noreferrer">
                  {p.name}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- こだわり: 2カラムの下に幅いっぱい -->
    <div class="highlight">
      <span class="highlight-label">こだわり</span>
      <p>
        フロントエンドとバックエンドを通して <strong>TypeScript で型を共有</strong>し、API の食い違いを防いでいます。
      </p>
    </div>
  </div>
</section>

<style>
  .note {
    max-width: var(--max-content);
    font-weight: 700;
    font-size: clamp(1rem, 4vw, 1.2rem);
    margin-bottom: 1.75rem;
  }

  .note strong {
    background: var(--accent-yellow);
    border-radius: 4px;
    padding: 0 0.2em;
  }

  .hint {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text-sub);
    margin-bottom: 1.1rem;
  }

  /* SP: 縦積み(stack-col → arch-col の順 = 技術 → 構成図) */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .layer-name {
    font-size: 1.15rem;
    margin: 0 0 0.9rem;
    display: inline-block;
    border-bottom: 4px solid var(--ink);
    padding-bottom: 0.2rem;
  }

  .layer + .layer {
    margin-top: 1.5rem;
  }

  .items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.75rem;
  }

  .tech {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    background: #fff;
    border: var(--border);
    border-radius: 14px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 0.7rem 0.9rem;
    text-decoration: none;
    color: var(--ink);
    transition: opacity 0.15s ease;
  }

  .tech:hover {
    opacity: 0.65;
  }

  .tech-logo {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    background-color: var(--tech-color);
    -webkit-mask: var(--icon) center / contain no-repeat;
    mask: var(--icon) center / contain no-repeat;
  }

  .tech-logo.is-text {
    display: grid;
    place-items: center;
    background-color: var(--tech-color);
    color: #fff;
    font-weight: 900;
    font-size: 0.95rem;
    border-radius: 7px;
    -webkit-mask: none;
    mask: none;
  }

  .tech-name {
    font-weight: 900;
    font-size: 0.95rem;
  }

  /* こだわり(2カラムの下・幅いっぱい) */
  .highlight {
    margin-top: 2.5rem;
    background: var(--cream);
    border: var(--border);
    border-left: 12px solid var(--accent-blue);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 1.1rem 1.25rem;
  }

  .highlight-label {
    display: inline-block;
    font-weight: 900;
    font-size: 0.78rem;
    color: #fff;
    background: var(--accent-blue);
    border-radius: 999px;
    padding: 0.15rem 0.8rem;
    margin-bottom: 0.5rem;
  }

  .highlight p {
    font-weight: 700;
    font-size: clamp(0.98rem, 3.5vw, 1.1rem);
  }

  .highlight strong {
    color: var(--accent-blue);
  }

  /* システム構成図 */
  .arch-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    border: var(--border-thick);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    background: #fff;
  }

  /* インフラ / プラットフォームのリンク行 */
  .platforms {
    margin-top: 1.1rem;
    max-width: 520px;
  }

  .platforms-label {
    display: block;
    font-weight: 900;
    font-size: 0.78rem;
    color: var(--text-sub);
    margin-bottom: 0.5rem;
  }

  .platform-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .platform-links a {
    font-weight: 900;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--ink);
    background: #fff;
    border: 2.5px solid var(--ink);
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--ink);
    padding: 0.3rem 0.9rem;
    transition: opacity 0.15s ease;
  }

  .platform-links a:hover {
    opacity: 0.65;
  }

  /* PC: 2カラム（左=構成図 sticky / 右=技術カード）。source 順は stack→arch だが
   * grid-template-areas で arch を左に再配置する。 */
  @media (min-width: 960px) {
    .grid {
      grid-template-columns: 0.85fr 1.15fr;
      grid-template-areas: 'arch stack';
      align-items: start;
      gap: 3rem;
    }

    .stack-col {
      grid-area: stack;
    }

    .arch-col {
      grid-area: arch;
      position: sticky;
      top: 72px;
    }

    .arch-img,
    .platforms {
      max-width: 100%;
    }
  }
</style>
