---
// 実装のこだわり詳細(技術ページ) — FE / BE。
//  FE: UI・UX(専門用語は避け、体験の工夫を平易に)
//  BE: 独自5軸スコアリングを「見て分かる」フローで図解(口頭で伝わりにくい部分)
import { AXES } from '../config';

const FE_POINTS = [
  {
    title: '構えさせない導線',
    body: '「テストを受けている」と意識させない流れ。ゲームに集中しているうちに、自然な行動が引き出されます。',
  },
  {
    title: '迷わない操作感',
    body: '次に何をすればいいかが一目でわかる画面設計。誰でも最後まで迷わずプレイできます。',
  },
  {
    title: '結果を見たくなる演出',
    body: '診断結果はキャラ名やチャートで分かりやすく。思わずシェアしたくなる見せ方にしています。',
  },
] as const;

// BE: 行動データ → 5軸スコア → ギャップ の流れ
const BE_STEPS = [
  {
    n: '01',
    title: '行動データを集める',
    body: 'クリック回数・反応時間・迷いなど、ゲーム中の無意識の操作を記録します。',
  },
  {
    n: '02',
    title: '独自の 5 軸でスコア化',
    body: '集めた行動データを 0〜100 に正規化し、5 つの軸ごとに点数化。各ゲームの結果を統合します。',
  },
  {
    n: '03',
    title: '自己申告とのギャップを出す',
    body: '事前アンケート（自己申告）と、行動から出た実測スコアを比較。ズレの大きさを可視化します。',
  },
] as const;
---

<section class="section section--cream section--roomy" id="craft-detail">
  <div class="section__inner">
    <h2 class="section-title"><span class="marker">実装のこだわり</span></h2>

    <div class="cols">
      <!-- FE -->
      <div class="col">
        <h3 class="col-head">
          <span class="col-tag" style="--c: var(--accent-blue)">Frontend</span>
          体験のつくりかた
        </h3>
        <ul class="fe-list">
          {
            FE_POINTS.map((p) => (
              <li class="fe-item">
                <span class="fe-title">{p.title}</span>
                <span class="fe-body">{p.body}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- BE -->
      <div class="col">
        <h3 class="col-head">
          <span class="col-tag" style="--c: var(--accent-red)">Backend</span>
          独自 5 軸スコアリング
        </h3>

        <ol class="be-flow">
          {
            BE_STEPS.map((s, i) => (
              <li class="be-step">
                <span class="be-no">{s.n}</span>
                <div class="be-text">
                  <span class="be-title">{s.title}</span>
                  <span class="be-body">{s.body}</span>
                </div>
                {i < BE_STEPS.length - 1 && <span class="be-arrow" aria-hidden="true">↓</span>}
              </li>
            ))
          }
        </ol>

        <!-- 5軸の中身を見せる -->
        <div class="axes-box">
          <span class="axes-label">診断する 5 つの軸</span>
          <ul class="axes">
            {
              AXES.map((a, i) => (
                <li class="axis">
                  <span class="axis-no">{String(i + 1).padStart(2, '0')}</span>
                  <span class="axis-name">{a.name}</span>
                  <span class="axis-range">{a.range}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <p class="be-note">
          自己申告との一致度を <strong>%</strong> で算出し、「自分が思う自分」とのズレを数値で示します。
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* FE / BE は常に縦積み(2カラムにすると窮屈で読みにくいため)。
   * セクション間を太い区切りで分け、それぞれを主役として大きく見せる。 */
  .cols {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
  }

  .col + .col {
    padding-top: 2.75rem;
    border-top: var(--border);
  }

  .col-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    font-size: clamp(1.2rem, 4vw, 1.5rem);
    margin: 0 0 1.25rem;
  }

  .col-tag {
    font-weight: 900;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--c);
    border: 2.5px solid var(--ink);
    border-radius: 999px;
    padding: 0.15rem 0.8rem;
  }

  /* FE: シンプルなリスト */
  .fe-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fe-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--card);
    border: var(--border);
    border-left: 10px solid var(--accent-blue);
    border-radius: 14px;
    box-shadow: var(--shadow);
    padding: 1rem 1.2rem;
  }

  .fe-title {
    font-weight: 900;
    font-size: 1.1rem;
  }

  .fe-body {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* BE: フロー */
  .be-flow {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .be-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: start;
    background: var(--card);
    border: var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    padding: 0.95rem 1.1rem;
    position: relative;
  }

  .be-no {
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--accent-red);
    font-variant-numeric: tabular-nums;
  }

  .be-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .be-title {
    font-weight: 900;
    font-size: 1.02rem;
  }

  .be-body {
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.88rem;
  }

  .be-arrow {
    position: absolute;
    left: 1.4rem;
    bottom: -0.55rem;
    font-weight: 900;
    color: var(--accent-red);
    z-index: 1;
  }

  /* 5軸ボックス */
  .axes-box {
    background: var(--card);
    border: var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 1.1rem 1.2rem;
  }

  .axes-label {
    display: block;
    font-weight: 900;
    font-size: 0.85rem;
    margin-bottom: 0.7rem;
  }

  .axes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .axis {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.6rem;
    background: var(--cream);
    border: 2.5px solid var(--ink);
    border-radius: 10px;
    padding: 0.5rem 0.8rem;
  }

  .axis-no {
    font-weight: 900;
    font-size: 0.9rem;
    color: var(--accent-red);
    font-variant-numeric: tabular-nums;
  }

  .axis-name {
    font-weight: 900;
    font-size: 1rem;
  }

  .axis-range {
    text-align: right;
    color: var(--text-sub);
    font-weight: 700;
    font-size: 0.78rem;
  }

  .be-note {
    margin-top: 1.1rem;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--text-sub);
  }

  .be-note strong {
    color: var(--accent-red);
    background: #fff;
    border-radius: 4px;
    padding: 0 0.2em;
  }

  /* FE のポイントは横に並べて密度を出す(縦積みでも間延びしないように) */
  @media (min-width: 640px) {
    .fe-list {
      flex-direction: row;
    }

    .fe-item {
      flex: 1;
    }

    .axes {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
