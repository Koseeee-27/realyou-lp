---
// 4-7. フッター — チーム名 / リンク 3 つ / CTA 再掲
import { LINKS, TEAM_NAME } from '../config';
---

<footer class="footer section">
  <!-- CTA 再掲 -->
  <a class="cta" href={LINKS.app} target="_blank" rel="noopener noreferrer">
    今すぐ本当の自分に会う →
  </a>

  <nav class="links">
    <a href={LINKS.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={LINKS.demo} target="_blank" rel="noopener noreferrer">デモ動画</a>
    <a href={LINKS.app} target="_blank" rel="noopener noreferrer">アプリを開く</a>
  </nav>

  <p class="team">{TEAM_NAME}</p>
</footer>

<style>
  .footer {
    text-align: center;
    padding-bottom: 4rem;
  }

  .links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 2rem 0 1.5rem;
  }

  .links a {
    font-weight: 900;
    text-decoration: none;
    background: var(--card);
    border: var(--border);
    border-radius: 999px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 0.5rem 1.25rem;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
  }

  .links a:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 var(--ink);
  }

  .team {
    font-weight: 900;
    font-size: 1.1rem;
  }
</style>
