---
// フッター — リンク + CTA 再掲。デモ動画・チーム名は表示しない。
import { LINKS } from '../config';
---

<footer class="footer section section--white">
  <div class="section__inner">
    <!-- CTA 再掲 -->
    <a class="cta" href={LINKS.app} target="_blank" rel="noopener noreferrer">
      今すぐ本当の自分に会う →
    </a>

    <nav class="links">
      <a href={LINKS.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={LINKS.app} target="_blank" rel="noopener noreferrer">アプリを開く</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    text-align: center;
    padding-bottom: 4rem;
  }

  .links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 2rem 0 0;
  }

  .links a {
    font-weight: 900;
    text-decoration: none;
    background: var(--card);
    border: var(--border);
    border-radius: 999px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 0.5rem 1.25rem;
    transition: opacity 0.15s ease, transform 0.08s ease, box-shadow 0.08s ease;
  }

  /* ホバーで少し薄く */
  .links a:hover {
    opacity: 0.7;
  }

  .links a:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 var(--ink);
  }
</style>
