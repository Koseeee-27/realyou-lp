---
// サイトヘッダー — テキストロゴ + ページ間リンク + CTA。
// current でページを判定し、もう一方のページへの導線を出す
//   home → 「技術・開発 →」(/tech)
//   tech → 「← プロダクト」(/)
import { APP_URL } from '../config';

interface Props {
  current?: 'home' | 'tech';
}
const { current = 'home' } = Astro.props;

const cross =
  current === 'home'
    ? { href: '/tech', label: '技術・開発 →' }
    : { href: '/', label: '← プロダクト' };
---

<header class="site-header">
  <div class="bar">
    <a class="brand" href="/" aria-label="Real You トップ">
      Real<span class="brand-y">You</span>
    </a>

    <nav class="nav">
      <a class="nav-link" href={cross.href}>{cross.label}</a>
      <a class="nav-cta" href={APP_URL} target="_blank" rel="noopener noreferrer">
        診断する
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: var(--border);
  }

  .bar {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.5rem var(--space);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* テキストロゴ(ワードマーク)。小サイズでも潰れず読める */
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.15em;
    font-weight: 900;
    font-size: 1.4rem;
    letter-spacing: 0.01em;
    color: var(--ink);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .brand:hover {
    opacity: 0.8;
  }

  /* "You" を黄色マーカーで強調してブランドのアクセントに */
  .brand-y {
    background: var(--accent-yellow);
    border: 2.5px solid var(--ink);
    border-radius: 8px;
    padding: 0 0.18em;
    line-height: 1.1;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-link {
    font-weight: 900;
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--ink);
    transition: opacity 0.15s ease;
  }

  /* ホバーで少し薄く */
  .nav-link:hover {
    opacity: 0.55;
  }

  .nav-cta {
    font-weight: 900;
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--ink);
    background: var(--accent-red);
    border: 3px solid var(--ink);
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--ink);
    padding: 0.35rem 1rem;
    transition: opacity 0.15s ease, transform 0.08s ease, box-shadow 0.08s ease;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  .nav-cta:active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 var(--ink);
  }

  @media (min-width: 860px) {
    .brand {
      font-size: 1.6rem;
    }

    .nav {
      gap: 1.25rem;
    }

    .nav-link,
    .nav-cta {
      font-size: 1rem;
    }
  }
</style>
