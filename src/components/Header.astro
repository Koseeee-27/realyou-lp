---
// 共通ヘッダー。テキストロゴ + 全ページへのナビ。
// current でいまのページを受け取り、該当タブをハイライトする。
import { APP_URL } from '../config';

interface Props {
  current?: 'home' | 'tech' | 'team';
}

const { current = 'home' } = Astro.props;

const PAGES = [
  { id: 'home', label: 'プロダクト', href: '/' },
  { id: 'tech', label: '技術・開発', href: '/tech' },
  { id: 'team', label: '開発体制', href: '/team' },
] as const;
---

<header class="hd">
  <div class="hd-inner">
    <a class="hd-logo" href="/">
      Real<span class="hd-y">You</span>
    </a>

    <nav class="hd-nav">
      {
        PAGES.map((p) => (
          <a
            class:list={['hd-link', { 'is-current': current === p.id }]}
            href={p.href}
            aria-current={current === p.id ? 'page' : undefined}
          >
            {p.label}
          </a>
        ))
      }
      <a class="hd-cta" href={APP_URL} target="_blank" rel="noopener noreferrer">
        試す
      </a>
    </nav>
  </div>
</header>

<style>
  .hd {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--card);
    border-bottom: var(--border);
  }

  .hd-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0.7rem var(--space);
  }

  .hd-logo {
    font-weight: 900;
    font-size: 1.4rem;
    text-decoration: none;
    color: var(--ink);
    white-space: nowrap;
  }

  .hd-y {
    background: var(--accent-yellow);
    border: 2px solid var(--ink);
    border-radius: 6px;
    padding: 0 0.15em;
    margin-left: 0.1em;
    display: inline-block;
  }

  .hd-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hd-link {
    font-weight: 900;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--ink);
    border: 2.5px solid transparent;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    background: transparent;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .hd-link:hover {
    opacity: 0.6;
  }

  /* 現在ページのタブは黄色マーカーで強調 */
  .hd-link.is-current {
    background: var(--accent-yellow);
    border-color: var(--ink);
  }

  .hd-cta {
    color: var(--ink);
    background: var(--accent-red);
    border: 2.5px solid var(--ink);
    border-radius: 999px;
    padding: 0.35rem 0.95rem;
    font-weight: 900;
    font-size: 0.85rem;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 3px 3px 0 var(--ink);
    transition: opacity 0.15s ease;
  }

  .hd-cta:hover {
    opacity: 0.85;
  }

  /* 狭い画面ではロゴを少し縮め、ナビの文字も詰める */
  @media (max-width: 480px) {
    .hd-logo {
      font-size: 1.2rem;
    }

    .hd-link {
      font-size: 0.78rem;
      padding: 0.3rem 0.5rem;
    }

    .hd-cta {
      font-size: 0.78rem;
      padding: 0.3rem 0.7rem;
    }

    .hd-nav {
      gap: 0.2rem;
    }
  }
</style>
