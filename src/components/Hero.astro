---
// Hero — 方向A「ギャップを主役」+ 1画面に意味を詰める3ブロック構成。
//   上: キッカー(小バッジ) / 中: 課題定義(見出し+≠+リード+CTA) / 下: セクション遷移ナビ+技術ページ+スクロール誘導
import { APP_URL } from '../config';

// 背景に散りばめる MBTI キャラ(public/characters/<TYPE>.png)。
//  - コンテンツ(テキスト・カード)の背面に薄く敷く装飾。位置は四隅〜余白に寄せる。
//  - hideSp: スマホでは間引いて表示する(詰め込みすぎ防止)。
const DECOR = [
  { type: 'ENFP', style: 'top: 7%;  left: 2%;   width: 92px; --rot: -10deg;', hideSp: false },
  { type: 'INTJ', style: 'top: 33%; right: 2%;  width: 80px; --rot: 9deg;',   hideSp: true },
  { type: 'ISFP', style: 'top: 55%; left: 1%;   width: 72px; --rot: 7deg;',   hideSp: true },
  { type: 'ESTP', style: 'bottom: 17%; left: 5%; width: 84px; --rot: -8deg;', hideSp: false },
  { type: 'ENTP', style: 'bottom: 9%;  right: 6%; width: 96px; --rot: 12deg;', hideSp: false },
  { type: 'INFJ', style: 'top: 13%; right: 13%; width: 66px; --rot: -6deg;',  hideSp: true },
  { type: 'ISTP', style: 'bottom: 40%; right: 3%; width: 68px; --rot: -11deg;', hideSp: true },
] as const;
---

<header class="hero">
  <!-- 背景装飾: MBTI キャラを散りばめる(コンテンツの背面) -->
  <div class="hero-decor" aria-hidden="true">
    {
      DECOR.map((d) => (
        <img
          class:list={['decor', { 'decor--hide-sp': d.hideSp }]}
          src={`/characters/${d.type}.png`}
          alt=""
          loading="lazy"
          style={d.style}
        />
      ))
    }
  </div>

  <!-- 上: キッカー -->
  <div class="kicker">
    <span class="kicker-badge"><span class="kicker-dot"></span>ゲームで暴く、本当の性格</span>
  </div>

  <!-- 中: 課題定義(メイン) -->
  <div class="inner">
    <h1 class="hook">
      その性格診断、<br />
      <mark>“理想の自分”</mark>で<br />
      答えてない？
    </h1>

    <div class="gap" aria-hidden="false">
      <div class="gap-card is-ideal">
        <span class="gap-label">あなたが思う、あなた</span>
        <span class="gap-sub">自己申告の性格</span>
      </div>

      <div class="gap-badge"><span class="gap-badge-mark">≠</span></div>

      <div class="gap-card is-real">
        <span class="gap-label">行動が、示すあなた</span>
        <span class="gap-sub">無意識の本性</span>
      </div>
    </div>

    <p class="lead">
      ゲーム中の<strong>“無意識の行動”</strong>を計測して、そのズレを暴く性格診断。
    </p>

    <a class="cta" href={APP_URL} target="_blank" rel="noopener noreferrer">
      無料で診断する →
    </a>
  </div>

  <!-- 下: 遷移ナビ -->
  <div class="hero-bottom">
    <nav class="jump" aria-label="セクションへ移動">
      <a class="jump-chip" href="#problem">課題</a>
      <a class="jump-chip" href="#solution">解決</a>
      <a class="jump-chip" href="#measure">何を測る</a>
      <a class="jump-chip" href="#results">結果</a>
      <a class="jump-chip" href="#craft">こだわり</a>
      <a class="jump-tech" href="/tech">技術・開発 →</a>
      <a class="jump-tech" href="/team">開発体制 →</a>
    </nav>
    <span class="scroll-hint" aria-hidden="true">
      スクロールで詳しく <span class="arrow">↓</span>
    </span>
  </div>
</header>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 1.75rem 0 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* --- 背景装飾: MBTI キャラ --- */
  .hero-decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* コンテンツ(キッカー/メイン/下部ナビ)を装飾より前面に出す */
  .hero > .kicker,
  .hero > .inner,
  .hero > .hero-bottom {
    position: relative;
    z-index: 1;
  }

  .decor {
    position: absolute;
    height: auto;
    /* 黄色背景になじませつつ「散らかってる」軽さを出す: 薄め + わずかに傾ける */
    opacity: 0.22;
    transform: rotate(var(--rot, 0deg));
    filter: saturate(1.1);
    user-select: none;
  }

  /* スマホでは数を絞る(間引き) */
  @media (max-width: 600px) {
    .decor--hide-sp {
      display: none;
    }

    .decor {
      opacity: 0.16;
    }
  }

  /* 上下ブロックも中央コンテナ幅に揃える */
  .kicker,
  .hero-bottom {
    width: 100%;
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  /* --- キッカー --- */
  .kicker {
    text-align: center;
  }

  .kicker-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 900;
    font-size: 0.9rem;
    background: #fff;
    border: 3px solid var(--ink);
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--ink);
    padding: 0.4rem 1.05rem;
  }

  .kicker-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent-red);
    border: 2px solid var(--ink);
  }

  /* --- 中: メイン --- */
  .inner {
    width: 100%;
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space);
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .hook {
    font-size: clamp(2rem, 9vw, 3rem);
    line-height: 1.25;
    letter-spacing: 0.01em;
    margin-bottom: 2rem;
  }

  .hook mark {
    background: var(--accent-yellow);
    border: 3px solid var(--ink);
    border-radius: 8px;
    box-shadow: 3px 3px 0 var(--ink);
    padding: 0 0.2em;
    display: inline-block;
    transform: rotate(-2deg);
  }

  /* --- ギャップのメインビジュアル --- */
  .gap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin: 0 auto 2rem;
    width: 100%;
    max-width: 340px;
  }

  .gap-card {
    width: 100%;
    border: var(--border-thick);
    border-radius: 18px;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .gap-label {
    font-weight: 900;
    font-size: clamp(1.1rem, 5vw, 1.4rem);
  }

  .gap-sub {
    font-weight: 700;
    font-size: 0.8rem;
    opacity: 0.65;
  }

  .is-ideal {
    background: #fff;
    color: var(--ink);
    transform: rotate(-2deg);
  }

  .is-real {
    background: #141414;
    color: #fff;
    transform: rotate(2deg);
  }

  .is-real .gap-label {
    color: var(--accent-red);
  }

  .gap-badge {
    position: relative;
    z-index: 2;
    width: 4rem;
    height: 4rem;
    margin: -0.7rem 0;
    display: grid;
    place-items: center;
    background: var(--accent-red);
    border: var(--border-thick);
    border-radius: 50%;
    box-shadow: 4px 4px 0 var(--ink);
  }

  .gap-badge-mark {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    color: #fff;
    text-shadow:
      -1.5px -1.5px 0 var(--ink),
      1.5px -1.5px 0 var(--ink),
      -1.5px 1.5px 0 var(--ink),
      1.5px 1.5px 0 var(--ink);
  }

  .lead {
    font-size: clamp(0.95rem, 4vw, 1.15rem);
    font-weight: 700;
    color: var(--text-sub);
    margin-bottom: 2rem;
  }

  .lead strong {
    color: var(--ink);
    background: var(--accent-yellow);
    border-radius: 4px;
    padding: 0 0.2em;
  }

  /* --- 下: 遷移ナビ --- */
  .hero-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .jump {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
  }

  .jump-chip,
  .jump-tech {
    font-weight: 900;
    font-size: 1rem;
    text-decoration: none;
    color: var(--ink);
    border: 3px solid var(--ink);
    border-radius: 999px;
    padding: 0.65rem 1.5rem;
    box-shadow: 4px 4px 0 var(--ink);
    transition: opacity 0.15s ease, transform 0.08s ease, box-shadow 0.08s ease;
  }

  .jump-chip {
    background: #fff;
  }

  /* 技術ページへの遷移はダーク pill で「別ページ」感を出す */
  .jump-tech {
    background: #141414;
    color: #fff;
  }

  .jump-chip:hover,
  .jump-tech:hover {
    opacity: 0.75;
  }

  .jump-chip:active,
  .jump-tech:active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 var(--ink);
  }

  .scroll-hint {
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--text-sub);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .scroll-hint .arrow {
    display: inline-block;
    animation: bob 1.4s ease-in-out infinite;
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-hint .arrow {
      animation: none;
    }
  }

  /*
   * PC(≥860px): ウィンドウ高に合わせた 1 画面。
   *   上=キッカー / 中=メイン(伸びて縦中央) / 下=遷移ナビ で余白を埋める。
   */
  @media (min-width: 860px) {
    .hero {
      min-height: calc(100vh - 56px);
      min-height: calc(100svh - 56px);
      padding: 1.5rem 0;
      gap: 1.5rem;
    }

    /* PC では横幅をもっと使う(余白を圧縮) */
    .kicker,
    .inner,
    .hero-bottom {
      max-width: 1200px;
    }

    .kicker {
      text-align: left;
    }

    .kicker-badge {
      font-size: 1rem;
      padding: 0.5rem 1.2rem;
    }

    /* メインが残り空間いっぱいに伸び、その中で縦中央 */
    .inner {
      flex: 1;
      align-content: center;
      grid-template-columns: 1.05fr 0.95fr;
      grid-template-areas:
        'hook gap'
        'lead gap'
        'cta  gap';
      align-items: center;
      column-gap: 4rem;
      justify-items: start;
      text-align: left;
    }

    .hook {
      grid-area: hook;
      font-size: clamp(3rem, 5vw, 4.6rem);
      margin-bottom: 2rem;
    }

    .lead {
      grid-area: lead;
      font-size: 1.35rem;
      margin-bottom: 2.5rem;
    }

    .cta {
      grid-area: cta;
      justify-self: start;
      font-size: 1.5rem;
      padding: 1.1rem 2.8rem;
    }

    .gap {
      grid-area: gap;
      margin: 0;
      max-width: 520px;
      justify-self: center;
      gap: 0.85rem;
    }

    .gap-card {
      padding: 2rem 2.2rem;
    }

    .gap-label {
      font-size: 1.85rem;
    }

    .gap-sub {
      font-size: 1rem;
    }

    .gap-badge {
      width: 4.4rem;
      height: 4.4rem;
      margin: -0.7rem 0;
    }

    .gap-badge-mark {
      font-size: 2.8rem;
    }

    /* 下部ナビは横一列: 左=セクション / 右=スクロール誘導。ボタンも大きく */
    .hero-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .jump {
      width: auto;
      justify-content: flex-start;
      gap: 0.8rem;
    }

    .jump-chip,
    .jump-tech {
      font-size: 1.15rem;
      padding: 0.8rem 1.8rem;
      box-shadow: 5px 5px 0 var(--ink);
    }

    .scroll-hint {
      font-size: 0.95rem;
    }
  }
</style>
