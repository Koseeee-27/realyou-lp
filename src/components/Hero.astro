---
// 4-1. Hero — 方向A「ギャップを主役に」
// プロダクトの核「自認 vs 実測のギャップ」を Hero のメインビジュアルとして見せる。
// ロゴ画像に名前+タグラインが入っているため、テキストでの再掲はしない(重複解消)。
import { APP_URL } from '../config';
---

<header class="hero">
  <div class="inner">
    <h1 class="hook">
      その性格診断、<br />
      <mark>“理想の自分”</mark>で<br />
      答えてない？
    </h1>

    <!-- ギャップのメインビジュアル: 思う自分 ≠ 行動が示す自分 -->
    <div class="gap" aria-hidden="false">
      <div class="gap-card is-ideal">
        <span class="gap-label">あなたが思う、あなた</span>
        <span class="gap-sub">自己申告の性格</span>
      </div>

      <div class="gap-badge"><span class="gap-badge-mark">≠</span></div>

      <div class="gap-card is-real">
        <span class="gap-label">行動が、示すあなた</span>
        <span class="gap-sub">無意識の本性</span>
      </div>
    </div>

    <p class="lead">
      ゲーム中の<strong>“無意識の行動”</strong>を計測して、<br />
      そのズレを暴く性格診断。
    </p>

    <a class="cta" href={APP_URL} target="_blank" rel="noopener noreferrer">
      無料で診断する →
    </a>
  </div>
</header>

<style>
  .hero {
    /* 横回転カードのはみ出しを抑える */
    overflow: hidden;
    padding: 2.5rem 0 3rem;
  }

  /*
   * モバイル: 1 カラムでセンター寄せ(従来どおり)。
   * DOM 順は hook → gap → lead → cta。単純な grid 縦積みで表示する。
   */
  .inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space);
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .hook {
    font-size: clamp(2rem, 9vw, 3rem);
    line-height: 1.25;
    letter-spacing: 0.01em;
    margin-bottom: 2rem;
  }

  .hook mark {
    background: var(--accent-yellow);
    border: 3px solid var(--ink);
    border-radius: 8px;
    box-shadow: 3px 3px 0 var(--ink);
    padding: 0 0.2em;
    /* 傾けて手書きラベル風に */
    display: inline-block;
    transform: rotate(-2deg);
  }

  /* --- ギャップのメインビジュアル --- */
  .gap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin: 0 auto 2rem;
    width: 100%;
    max-width: 340px;
  }

  .gap-card {
    width: 100%;
    border: var(--border-thick);
    border-radius: 18px;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .gap-label {
    font-weight: 900;
    font-size: clamp(1.1rem, 5vw, 1.4rem);
  }

  .gap-sub {
    font-weight: 700;
    font-size: 0.8rem;
    opacity: 0.65;
  }

  /* 思う自分: 明るい・理想 */
  .is-ideal {
    background: #fff;
    color: var(--ink);
    transform: rotate(-2deg);
  }

  /* 行動が示す自分: ダーク・本性 */
  .is-real {
    background: #141414;
    color: #fff;
    transform: rotate(2deg);
  }

  .is-real .gap-label {
    color: var(--accent-red);
  }

  /* 中央の ≠ バッジ(ズレの記号)。視認性優先で大きく・回転なし・高コントラスト */
  .gap-badge {
    position: relative;
    z-index: 2;
    width: 4rem;
    height: 4rem;
    margin: -0.7rem 0;
    display: grid;
    place-items: center;
    background: var(--accent-red);
    border: var(--border-thick);
    border-radius: 50%;
    box-shadow: 4px 4px 0 var(--ink);
  }

  /* ≠ グリフは細く見えがちなので、太字 + 大きめ + 白で明確に */
  .gap-badge-mark {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    color: #fff;
    /* 黒フチでさらにくっきり */
    text-shadow:
      -1.5px -1.5px 0 var(--ink),
      1.5px -1.5px 0 var(--ink),
      -1.5px 1.5px 0 var(--ink),
      1.5px 1.5px 0 var(--ink);
  }

  .lead {
    font-size: clamp(0.95rem, 4vw, 1.15rem);
    font-weight: 700;
    color: var(--text-sub);
    margin-bottom: 2rem;
  }

  .lead strong {
    color: var(--ink);
    background: var(--accent-yellow);
    border-radius: 4px;
    padding: 0 0.2em;
  }

  /*
   * PC(≥860px): 横幅を活かした 2 カラム。
   * 左 = コピー(ロゴ→見出し→リード→CTA)、右 = ギャップ・ビジュアル。
   * grid-template-areas で DOM 順を変えずに再配置する。gap は同名エリアを
   * 全行に置くことで右カラムを縦に貫く(= 左の4要素ぶんの高さを占める)。
   */
  @media (min-width: 860px) {
    .hero {
      padding: 4.5rem 0 5rem;
    }

    .inner {
      max-width: 1080px;
      grid-template-columns: 1.05fr 0.95fr;
      grid-template-areas:
        'hook gap'
        'lead gap'
        'cta  gap';
      align-items: center;
      column-gap: 3.5rem;
      justify-items: start;
      text-align: left;
    }

    .hook {
      grid-area: hook;
      font-size: clamp(2.6rem, 4.2vw, 3.8rem);
      margin-bottom: 1.75rem;
    }

    .lead {
      grid-area: lead;
      font-size: 1.2rem;
      margin-bottom: 2.25rem;
    }

    .cta {
      grid-area: cta;
      justify-self: start;
      font-size: 1.35rem;
      padding: 1rem 2.5rem;
    }

    /* 右カラムのギャップ・ビジュアルを大きく見せる */
    .gap {
      grid-area: gap;
      margin: 0;
      max-width: 440px;
      justify-self: center;
      gap: 0.75rem;
    }

    .gap-card {
      padding: 1.6rem 1.9rem;
    }

    .gap-label {
      font-size: 1.6rem;
    }

    .gap-sub {
      font-size: 0.9rem;
    }

    .gap-badge {
      width: 3.8rem;
      height: 3.8rem;
      margin: -0.6rem 0;
      font-size: 2.2rem;
    }
  }
</style>
